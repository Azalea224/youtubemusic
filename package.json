{
  "name": "youtube-music-client",
  "private": true,
  "version": "0.3.1-alpha",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:electron": "node electron/scripts/playback-ad.test.cjs",
    "test:all": "npm run test:run && npm run test:electron",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "npm run build && node scripts/copy-icon.cjs && electron-builder"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.1",
    "cross-fetch": "^4.1.0",
    "discord-rich-presence": "^0.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "electron": "^40.8.4",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "patch-package": "^8.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.youtube-music.client",
    "productName": "YouTube Music",
    "artifactName": "YouTubeMusic-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "linux": {
      "executableName": "youtube-music-client",
      "icon": "build/icons",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Audio",
      "maintainer": "YouTube Music Client <noreply@example.com>"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "plugins/**/*",
      "public/icon.png"
    ],
    "extraResources": [
      {
        "from": "plugins",
        "to": "plugins"
      }
    ]
  },
  "description": "YouTube Music desktop client with plugins and Discord Rich Presence",
  "homepage": "https://github.com/Azalea224/youtubemusic",
  "author": "Azalea224"
}
