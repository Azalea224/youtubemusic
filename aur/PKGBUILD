pkgname=youtube-music-client-bin
pkgver=0.3.1_alpha
pkgrel=1
pkgdesc="YouTube Music desktop client (binary AppImage)"
arch=('x86_64' 'aarch64')
url="https://github.com/Azalea224/youtubemusic"
license=('MIT')
depends=('gtk3' 'nss' 'alsa-lib' 'libxss' 'libxtst' 'mesa')
provides=('youtube-music-client')
conflicts=('youtube-music-client' 'youtube-music-client-git')
options=('!strip')

_appname="youtube-music-client"
_repo_owner="Azalea224"
_repo_name="youtubemusic"

source_x86_64=(
  "${_appname}.AppImage::https://github.com/${_repo_owner}/${_repo_name}/releases/download/v${pkgver//_/-}/YouTubeMusic-${pkgver//_/-}-linux-x64.AppImage"
  "${_appname}.png::https://raw.githubusercontent.com/${_repo_owner}/${_repo_name}/v${pkgver//_/-}/public/icon.png"
  "${_appname}.desktop"
  "${_appname}"
)
source_aarch64=(
  "${_appname}.AppImage::https://github.com/${_repo_owner}/${_repo_name}/releases/download/v${pkgver//_/-}/YouTubeMusic-${pkgver//_/-}-linux-arm64.AppImage"
  "${_appname}.png::https://raw.githubusercontent.com/${_repo_owner}/${_repo_name}/v${pkgver//_/-}/public/icon.png"
  "${_appname}.desktop"
  "${_appname}"
)

sha256sums_x86_64=('SKIP' 'SKIP' 'SKIP' 'SKIP')
sha256sums_aarch64=('SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
  install -d "${pkgdir}/opt/${_appname}"
  install -Dm755 "${srcdir}/${_appname}.AppImage" "${pkgdir}/opt/${_appname}/${_appname}.AppImage"
  chmod +x "${pkgdir}/opt/${_appname}/${_appname}.AppImage"

  install -Dm755 "${srcdir}/${_appname}" "${pkgdir}/usr/bin/${_appname}"
  install -Dm644 "${srcdir}/${_appname}.desktop" "${pkgdir}/usr/share/applications/${_appname}.desktop"
  install -Dm644 "${srcdir}/${_appname}.png" "${pkgdir}/usr/share/pixmaps/${_appname}.png"
}
