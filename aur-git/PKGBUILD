pkgname=youtube-music-client-git
pkgver=0.3.0.alpha.hotfix.r0.g0d4ddd0
pkgrel=1
pkgdesc="YouTube Music desktop client (builds unpacked Linux app from git)"
arch=('x86_64' 'aarch64')
url="https://github.com/Azalea224/youtubemusic"
license=('MIT')
depends=('gtk3' 'nss' 'alsa-lib' 'libxss' 'libxtst' 'mesa')
makedepends=('git' 'nodejs' 'npm' 'python')
provides=('youtube-music-client')
conflicts=('youtube-music-client' 'youtube-music-client-bin')
options=('!strip')

_appname="youtube-music-client"

source=(
  "git+${url}.git"
  "${_appname}"
  "${_appname}.desktop"
)
sha256sums=(
  'SKIP'
  'SKIP'
  'SKIP'
)

pkgver() {
  cd "${srcdir}/youtubemusic"
  git describe --long --tags --abbrev=7 2>/dev/null \
    | sed 's/^v//; s/\([^-]*\)-\([0-9]*\)-g/\1.r\2.g/; s/-/./g' \
    || printf '0.0.0.r0.g%s\n' "$(git rev-parse --short=7 HEAD)"
}

prepare() {
  cd "${srcdir}/youtubemusic"
  npm ci
}

build() {
  cd "${srcdir}/youtubemusic"
  npm run electron:build -- --linux dir --publish never
}

package() {
  cd "${srcdir}/youtubemusic"

  install -d "${pkgdir}/opt/${_appname}"

  if [[ ! -d release/linux-unpacked ]]; then
    printf 'ERROR: release/linux-unpacked not found after electron-builder\n' >&2
    return 1
  fi
  cp -a release/linux-unpacked/. "${pkgdir}/opt/${_appname}/"

  local main_bin="${pkgdir}/opt/${_appname}/youtube-music-client"
  if [[ ! -f "${main_bin}" ]]; then
    printf 'ERROR: Expected main binary not found: %s\n' "${main_bin}" >&2
    return 1
  fi
  chmod 755 "${main_bin}"

  install -Dm755 "${srcdir}/${_appname}" "${pkgdir}/usr/bin/${_appname}"
  install -Dm644 "${srcdir}/${_appname}.desktop" "${pkgdir}/usr/share/applications/${_appname}.desktop"
  install -Dm644 "public/icon.png" "${pkgdir}/usr/share/pixmaps/${_appname}.png"
}
